{
  "name": "mcp-to-cli",
  "version": "0.1.0",
  "description": "Connect to remote MCP servers from the command line",
  "bin": {
    "mcp-to-cli": "./src/cli.ts"
  },
  "type": "module",
  "module": "src/cli.ts",
  "scripts": {
    "start": "bun src/cli.ts",
    "dev": "bun --watch src/cli.ts",
    "lint": "oxlint --deny-warnings .",
    "lint:fix": "oxlint --fix .",
    "fmt": "oxfmt --write . && bun run lint:fix",
    "fmt:check": "oxfmt --check .",
    "typecheck": "tsc --noEmit",
    "check": "bun run fmt:check && bun run lint && bun run typecheck"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^14.0.3",
    "inquirer": "^13.3.0",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
